# Environment Configuration
# Copy this file to .env.local and fill in your actual values

# API Configuration
VITE_API_BASE_URL=https://scaredrealm.com/speedy_fix_node_backend/api/v1/

# Google Maps API Key (Required for map features)
# Put your real key in `.env.local` (do not commit it) and set it in Vercel Environment Variables for production.
# Get your key from: https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=AIzaSyDaGvunBG7npH3gniMbklfJwjKrjxJ6N4Y

# Google AdSense Configuration
# Your Publisher ID: pub-6858918029295433
# AdSense client format must be: ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_ENABLED=true
VITE_ADSENSE_CLIENT=ca-pub-6858918029295433

# Inline ad slots used inside list/detail content areas
VITE_ADSENSE_INLINE_LIST_SLOT=5182233001
VITE_ADSENSE_INLINE_DETAIL_SLOT=5182233001

# Optional defaults used by <AdSenseSlot /> when not overridden
# For “fluid” in-article style ads
VITE_ADSENSE_DEFAULT_FORMAT=fluid
VITE_ADSENSE_DEFAULT_LAYOUT=in-article

# Alternative fluid layout using layout-key (leave empty unless your ad unit requires it)
VITE_ADSENSE_DEFAULT_LAYOUT_KEY=

# Keep test mode enabled in local development only
VITE_ADSENSE_TEST_MODE=true